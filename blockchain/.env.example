# ─── Blockchain ────────────────────────────────────────────────────────────────
# Your server wallet private key (the deployer/owner wallet)
# NEVER commit this. Export from MetaMask → Account Details → Show Private Key
PRIVATE_KEY=your_private_key_here

# Deployed SangPoints contract address (filled in after running deploy.js)
CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000

# Polygon Amoy RPC (public endpoint — you can also use Alchemy/Infura for reliability)
AMOY_RPC_URL=https://rpc-amoy.polygon.technology/

# Demo wallet address (Aarav's MetaMask wallet for the hackathon demo)
DEMO_WALLET=0xeC5eA63092348C7B473678F2F41875963527a895

# PolygonScan API key (for contract verification — free at polygonscan.com)
POLYGONSCAN_API_KEY=your_polygonscan_api_key_here

# ─── Next.js (backend team fills these in) ─────────────────────────────────────
# DATABASE_URL=postgresql://...
# JWT_SECRET=...
# FIREBASE_SERVICE_ACCOUNT=...
