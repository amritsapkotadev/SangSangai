# Database configuration (Supabase/PostgreSQL)
DATABASE_URL=postgresql://user:password@localhost:5432/sangsangai

# JWT secret for token verification
JWT_SECRET=your_jwt_secret_here

# Firebase Admin SDK credentials
FIREBASE_SERVICE_ACCOUNT=your_firebase_service_account_json_here

# Blockchain configuration (Polygon Amoy Testnet)
PRIVATE_KEY=your_deployer_wallet_private_key_here
CONTRACT_ADDRESS=your_deployed_contract_address_here
AMOY_RPC_URL=https://rpc-amoy.polygon.technology/
