# Supabase (public keys for client-side usage)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Service role key for server-side operations (get from Supabase Dashboard → Settings → API → service_role key)
SUPABASE_SERVICE_ROLE_KEY=

# Prisma — needs the full PostgreSQL connection string from Supabase
DATABASE_URL=

# Auth
JWT_SECRET="change-this-to-a-random-secret-in-production"

# Firebase (JSON string of service account key)
FIREBASE_SERVICE_ACCOUNT_KEY='{"type":"service_account","project_id":"your-project"}'

# ─── Local Blockchain Secrets ──────────────────────────────────────────────────
# Paste your SangSangai Dev account private key here (export from MetaMask)
PRIVATE_KEY=

# Deployed contract address (generated after running deploy.js)
CONTRACT_ADDRESS=0xed11E37241D89399Bf15978e670b8FDB36a6D6eE

# Polygon Amoy RPC url
AMOY_RPC_URL=https://polygon-amoy.g.alchemy.com/v2/your-api-key

# Guide/Dev wallet address (for testing)
DEMO_WALLET=
